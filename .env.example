# Copy this to .env and fill in your values
POSTGRES_USER=sleepuser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sleepdb
DATABASE_URL=postgresql://sleepuser:change_me_strong_password@db:5432/sleepdb
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=your_garmin_password
GARMIN_TOKEN_DIR=/app/garmin_tokens
GARMIN_SLEEP_BACKFILL_DAYS=30
GARMIN_BODY_BACKFILL_DAYS=30
GARMIN_HRV_BACKFILL_DAYS=30
GARMIN_RHR_BACKFILL_DAYS=30
GARMIN_STRESS_BACKFILL_DAYS=30
GARMIN_HYDRATION_BACKFILL_DAYS=30
GARMIN_AUTOSYNC_ENABLED=true
API_BASE=http://backend:8000
BACKEND_IMAGE=ghcr.io/notascooby25/sleep-wellness-tracker-backend:latest
FRONTEND_IMAGE=ghcr.io/notascooby25/sleep-wellness-tracker-frontend:latest

# --- Security (optional but recommended for exposed deployments) ---
# Set API_KEY to a strong random secret to protect the backend API.
# All requests (except /health) must include the header: X-API-Key: <value>
# Leave empty or unset to disable authentication (default).
# Generate a suitable value with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Set CORS_ORIGINS to a comma-separated list of origins allowed to make
# cross-origin browser requests to the backend API, e.g.:
#   CORS_ORIGINS=http://localhost:8505,https://my.domain.com
# Leave empty or unset to block all cross-origin browser requests (default).
CORS_ORIGINS=
