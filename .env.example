# Environment template — copy to .env and fill in your values
# NEVER commit .env to git — it's in .gitignore

# PostgreSQL Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# FastAPI Backend
DATABASE_URL=postgresql://postgres:postgres@db:5432/postgres

# Streamlit Frontend
API_BASE=http://backend:8000

# Garmin Connect (OPTIONAL — integration will be disabled if not set)
# Set these to enable Garmin sleep & wellness data sync
# Create a dedicated Garmin account if desired (not your primary account)
GARMIN_EMAIL=your-garmin-email@example.com
GARMIN_PASSWORD=your-garmin-password
